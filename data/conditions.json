{
  "operators": [">=", "<=", "==", "!=", ">", "<"],
  "joiners": {
    "&": "AND",
    "@": "OR",
    "|": "OR"
  },
  "fields": {
    "phase": {
      "values": {
        "0": "Early race",
        "1": "Mid race",
        "2": "Late race",
        "3": "Last spurt"
      },
      "ops": {
        ">=": "{value} and beyond",
        "<=": "Early race through {value}",
        "==": "{value}",
        "!=": "Not {value}"
      }
    },
    "phase_random": {
      "values": {
        "0": "Random point in early race",
        "1": "Random point in mid race",
        "2": "Random point in late race",
        "3": "Random point in last spurt phase"
      }
    },
    "phase_laterhalf_random": {
      "values": {
        "0": "Random point in the second half of early race"
      }
    },
    "phase_firsthalf_random": {
      "values": {
        "3": "Random point in the first half of last spurt phase"
      }
    },
    "distance_type": {
      "values": {
        "1": "Sprint",
        "2": "Mile",
        "3": "Medium",
        "4": "Long"
