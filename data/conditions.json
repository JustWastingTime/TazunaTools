      "ops": {
        "==": { "0": "Right beside the inner fence" },
        "<=": { "0.2": "Inner lane" },
        ">=": {
          "0.2": "Middle lane or outer",
          "0.4": "Outer lane or outside",
          "0.6": "Outside lane"
